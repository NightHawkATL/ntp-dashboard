<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NTP Dashboard</title>
    <script src="/static/tailwindcss.js"></script>
    <script>tailwind.config = { darkMode: 'class' }</script>
    <style>
        @keyframes ping-slow { 0% {transform: scale(1); opacity: 0.8;} 50% {transform: scale(2.5); opacity: 0;} 100% {transform: scale(1); opacity: 0;} }
        .ping-slow { animation: ping-slow 2s cubic-bezier(0,0,0.2,1) infinite; transform-origin: center; }
    </style>
</head>
<body class="bg-gray-100 text-gray-900 dark:bg-gray-900 dark:text-gray-100 min-h-screen">
    <div class="container mx-auto px-4 py-8 max-w-6xl">
        <div class="flex flex-col sm:flex-row justify-between items-center mb-6 gap-4">
            <h1 class="text-3xl font-bold text-blue-500">NTP & GPS Dashboard</h1>
            <div class="flex gap-4">
                <button onclick="document.documentElement.classList.toggle('dark')" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-800 font-medium">Toggle Mode</button>
                <button onclick="openSettings()" class="px-4 py-2 rounded-lg bg-blue-500 text-white font-medium">Connection Setup</button>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-6">
                <h2 class="text-xl font-semibold mb-2">System Time Status (2s)</h2>
                <div class="text-xl font-mono text-green-500 font-bold" id="sysOffset">Loading...</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow p-6">
                <h2 class="text-xl font-semibold mb-2">Connection Target</h2>
                <div class="text-lg font-medium text-blue-500" id="connMode">Loading...</div>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow overflow-hidden mb-6">
            <h2 class="p-4 border-b dark:border-gray-700 font-semibold">NTP Sources (chronyc sources)</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm font-mono">
                    <thead class="bg-gray-50 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
                        <tr><th class="p-4">State</th><th class="p-4">Source</th><th class="p-4">Stratum</th><th class="p-4">Poll</th><th class="p-4">Reach</th><th class="p-4">LastRx</th><th class="p-4">Offset</th></tr>
                    </thead>
                    <tbody id="ntpTableBody" class="divide-y dark:divide-gray-700"></tbody>
                </table>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl shadow overflow-hidden mb-8 flex flex-col lg:flex-row">
            <div class="p-6 bg-[#0a0f1a] flex flex-col items-center justify-center relative w-full lg:w-1/3 border-r dark:border-gray-700">
                <h2 class="text-white font-semibold mb-4 w-full text-center">GPS Skyplot (30s Sweep)</h2>
                <div class="w-full h-1 bg-gray-800 mb-4 rounded"><div id="sweepBar" class="h-full bg-blue-500 transition-all duration-1000" style="width:100%"></div></div>
                <div class="relative w-64 h-64">
                    <svg viewBox="0 0 200 200" class="w-full h-full rounded-full shadow-[0_0_30px_rgba(59,130,246,0.2)]">
                        <circle cx="100" cy="100" r="100" fill="#0f172a" />
                        <ellipse cx="100" cy="100" rx="100" ry="35" fill="none" stroke="rgba(255,255,255,0.15)" /><ellipse cx="100" cy="100" rx="35" ry="100" fill="none" stroke="rgba(255,255,255,0.15)" />
                        <circle cx="100" cy="100" r="99" fill="none" stroke="rgba(255,255,255,0.3)" />
                        <line x1="100" y1="0" x2="100" y2="200" stroke="rgba(255,255,255,0.15)" /><line x1="0" y1="100" x2="200" y2="100" stroke="rgba(255,255,255,0.15)" />
                        <g id="satellitesLayer"></g>
                    </svg>
                </div>
            </div>
            <div class="flex-1 overflow-x-auto h-96 overflow-y-auto">
                <div class="p-4 border-b dark:border-gray-700 flex justify-between bg-gray-50 dark:bg-gray-800 sticky top-0">
                    <span class="font-semibold">Satellites (gpspipe)</span>
                    <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-800 font-bold text-sm" id="satCount">0 Locked</span>
                </div>
                <table class="w-full text-left text-sm font-mono">
                    <thead class="bg-gray-50 dark:bg-gray-700"><tr><th class="p-4">PRN</th><th class="p-4">Elev</th><th class="p-4">Azim</th><th class="p-4">Signal (SNR)</th><th class="p-4">Status</th></tr></thead>
                    <tbody id="satTableBody" class="divide-y dark:divide-gray-700"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div id="settingsModal" class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 px-4 flex">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-md p-6">
            <h2 class="text-2xl font-bold mb-4">Config</h2>
            <form id="configForm">
                <select id="mode" class="w-full mb-4 p-2 rounded border dark:bg-gray-700 dark:border-gray-600 outline-none" onchange="toggleRemote()">
                    <option value="local">Local Host Exec</option><option value="remote">Remote SSH Exec</option>
                </select>
                <div id="remoteFields" class="hidden space-y-4 mb-4">
                    <input type="text" id="host" class="w-full p-2 rounded border dark:bg-gray-700 dark:border-gray-600" placeholder="Target IP">
                    <input type="text" id="user" class="w-full p-2 rounded border dark:bg-gray-700 dark:border-gray-600" placeholder="SSH Username">
                    <input type="password" id="password" class="w-full p-2 rounded border dark:bg-gray-700 dark:border-gray-600" placeholder="SSH Password (optional)">
                </div>
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="closeSettings()" class="px-4 py-2 rounded bg-gray-200 dark:bg-gray-700">Cancel</button>
                    <button type="submit" class="px-4 py-2 rounded bg-blue-500 text-white">Save</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const modal = document.getElementById('settingsModal');
        function openSettings() { modal.classList.remove('hidden'); }
        function closeSettings() { modal.classList.add('hidden'); }
        function toggleRemote() { document.getElementById('remoteFields').classList.toggle('hidden', document.getElementById('mode').value === 'local'); }

        async function loadUI() {
            const conf = await (await fetch('/api/config')).json();
            document.getElementById('mode').value = conf.mode || 'local';
            document.getElementById('host').value = conf.host || '';
            document.getElementById('user').value = conf.user || '';
            document.getElementById('connMode').innerText = conf.mode === 'local' ? 'Local System' : `SSH: ${conf.user}@${conf.host}`;
            toggleRemote();
        }

        document.getElementById('configForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            await fetch('/api/config', {
                method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({mode: document.getElementById('mode').value, host: document.getElementById('host').value, user: document.getElementById('user').value, password: document.getElementById('password').value})
            });
            closeSettings(); loadUI(); fetchNTP(); fetchGPS();
        });

        async function fetchNTP() {
            const d = await (await fetch('/api/ntp')).json();
            if(d.error) return document.getElementById('sysOffset').innerText = "Error: Check Config";
            document.getElementById('sysOffset').innerText = d.offset;
            document.getElementById('ntpTableBody').innerHTML = d.sources.map(s => `<tr class="${s.name.includes('PPS')?'text-blue-500 font-bold':''}"><td class="p-4">${s.state}</td><td class="p-4">${s.name}</td><td class="p-4">${s.stratum}</td><td class="p-4">${s.poll}</td><td class="p-4">${s.reach}</td><td class="p-4">${s.lastrx}</td><td class="p-4">${s.last_sample}</td></tr>`).join('');
        }

        let timer = 30;
        async function fetchGPS() {
            const sats = (await (await fetch('/api/gps')).json()).satellites ||